---
import AppLayout from '../components/layout/AppLayout.astro';
import MainBanner from '../components/layout/MainBanner.astro';
import { getPublicName, students } from '../lib/data';
import { rankStudents } from '../lib/ranking';
import { withBase } from '../lib/url';

const searchStudents = rankStudents(students).map((student) => ({
  name: getPublicName(student),
  className: student.className,
  points: student.pointsTotal,
  badges: student.badges.length,
  avatar: withBase(student.avatarPath),
  href: withBase(`/alunos/${student.slug}/`)
}));
---

<AppLayout title="Busca de aluno">
  <MainBanner />

  <section class="search-panel surface">
    <label for="student-search" class="eyebrow">Digite para filtrar</label>
    <input
      id="student-search"
      class="search-input"
      type="search"
      placeholder="Ex.: Ana, Turma Alpha, programacao"
      autocomplete="off"
      data-search-input
    />
    <div class="search-results" data-search-results></div>
  </section>
</AppLayout>

<script is:inline define:vars={{ searchStudents }}>
  const input = document.querySelector('[data-search-input]');
  const results = document.querySelector('[data-search-results]');

  function render(items) {
    if (!results) return;
    results.innerHTML = '';

    if (items.length === 0) {
      const empty = document.createElement('p');
      empty.className = 'privacy-note surface';
      empty.textContent = 'Nenhum aluno publico encontrado para essa busca.';
      results.append(empty);
      return;
    }

    items.forEach((student) => {
      const card = document.createElement('a');
      card.className = 'result-card surface';
      card.href = student.href;
      card.innerHTML = `
        <span class="identity">
          <img src="${student.avatar}" alt="Avatar de ${student.name}" loading="lazy" />
          <span>
            <strong>${student.name}</strong>
            <span>${student.className} - ${student.badges} badges</span>
          </span>
        </span>
        <span class="rank-pill">${student.points}</span>
      `;
      results.append(card);
    });
  }

  function normalize(value) {
    return value.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
  }

  input?.addEventListener('input', () => {
    const query = normalize(input.value);
    const filtered = searchStudents.filter((student) => {
      const haystack = normalize(`${student.name} ${student.className}`);
      return haystack.includes(query);
    });
    render(filtered);
  });

  render(searchStudents);
</script>
